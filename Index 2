function renderFldtCustom(){ const [p1,p2]=[fldtData.p1,fldtData.p2]; buildFldtMainTable([p1,p2],['P1','P2']); destroyChart('fldtCustBar'); charts.fldtCustBar=new Chart(document.getElementById('fldt-custom-bar'),{type:'bar',data:{labels:FLDT_LABELS,datasets:[{label:'P1',data:FLDT_KEYS.map(k=>p1[k]||0)},{label:'P2',data:FLDT_KEYS.map(k=>p2[k]||0)}]},options:baseOptions('num')}); buildFldtDoughnut('fldt-custom-dough1',p1); buildFldtDoughnut('fldt-custom-dough2',p2); }

// ========== ALL SUMMARY PAGE ==========
function loadAllSumm(){ const s1=document.getElementById('summ-p1s').value, e1=document.getElementById('summ-p1e').value; if(!s1||!e1||!allData.length) return; const d1=aggregateData(filterData(s1,e1)); const s2=document.getElementById('summ-p2s').value, e2=document.getElementById('summ-p2e').value; const d2=(s2&&e2)?aggregateData(filterData(s2,e2)):null; document.getElementById('summ-content').style.display='block'; document.getElementById('summ-kpi-row').innerHTML=`<div>GMV: ${fmtRp(d1.gmv)}</div><div>AT: ${fmtRp(d1.gmv/(d1.adt_store||1))}</div>`; const chans=['offline','gofood','grabfood','shopee']; document.getElementById('summ-chan-rank').innerHTML=chans.map(c=>`<div>${c}: ${fmtRp(d1[c])}</div>`).join(''); document.getElementById('summ-fldt-grid').innerHTML=FLDT_KEYS.map((k,i)=>`<div>${FLDT_LABELS[i]}: ${fmtNum(d1[k])}</div>`).join(''); }

// ========== D2D PAGE ==========
function loadD2D(){ const s=document.getElementById('d2d-start').value, e=document.getElementById('d2d-end').value; if(!s||!e||!allData.length) return; const rows=filterData(s,e); if(!rows.length){ document.getElementById('d2d-table-wrap').innerHTML='<div>Tidak ada data</div>'; return; } let html='<table><thead><tr><th>Tanggal</th><th>GMV</th><th>Offline</th><th>GoFood</th></tr></thead><tbody>'; rows.forEach(r=>{ html+=`<tr><td>${r.date}</td><td>${fmtRp(r.gmv)}</td><td>${fmtRp(r.offline)}</td><td>${fmtRp(r.gofood)}</td></tr>`; }); html+='</tbody></table>'; document.getElementById('d2d-table-wrap').innerHTML=html; }

// ========== UI ENHANCEMENTS ==========
function buildDock(){ const pages=['kpi','channel','period','fldt','allsumm','d2d']; const labels=['KPI','CHANNEL','W/W','FLDT','SUMMARY','D2D']; const dock=document.getElementById('floatingDock'); dock.innerHTML=''; pages.forEach((p,i)=>{ const btn=document.createElement('button'); btn.className='dock-item'+(currentPage===p?' active':''); btn.innerText=labels[i]; btn.onclick=()=>{ showPage(p,btn); }; dock.appendChild(btn); }); }
function commandPaletteInit(){ const modal=document.getElementById('cmdModal'); const input=document.getElementById('cmdInput'); const listDiv=document.getElementById('cmdList'); const commands=['kpi','channel','period','fldt','allsumm','d2d','refresh']; function render(filter=''){ listDiv.innerHTML=commands.filter(c=>c.includes(filter.toLowerCase())).map(c=>`<div class="cmd-item" data-cmd="${c}">${c.toUpperCase()}</div>`).join(''); } render(); listDiv.onclick=e=>{ const cmd=e.target.closest('.cmd-item')?.dataset.cmd; if(cmd==='refresh') loadData(); else showPage(cmd); modal.classList.remove('active'); }; input.oninput=()=>render(input.value); document.addEventListener('keydown',e=>{ if((e.metaKey||e.ctrlKey)&&e.key==='k'){ e.preventDefault(); modal.classList.toggle('active'); if(modal.classList.contains('active')) input.focus(); } }); document.getElementById('cmdLauncher').onclick=()=>{ modal.classList.toggle('active'); input.focus(); }; modal.onclick=e=>{ if(e.target===modal) modal.classList.remove('active'); }; }
window.calcKpi=calcKpi; window.applyChannelFilter=applyChannelFilter; window.resetChannelFilter=resetChannelFilter; window.loadPeriod=loadPeriod; window.loadCustomPeriod=loadCustomPeriod; window.setPeriodMode=setPeriodMode; window.setFldtMode=setFldtMode; window.setFldtChan=setFldtChan; window.loadFldtCustom=loadFldtCustom; window.loadAllSumm=loadAllSumm; window.loadD2D=loadD2D; window.setWeeklyChan=setWeeklyChan; window.setCustomChan=setCustomChan;
document.getElementById('refreshBtn').onclick=()=>loadData();
commandPaletteInit(); buildDock(); loadData();
</script>
