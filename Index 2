}
.logo { font-weight: 800; font-size: 1.4rem; background: linear-gradient(135deg, #fff, var(--accent-primary)); -webkit-background-clip: text; background-clip: text; color: transparent; }
.store-badge { font-size: 0.7rem; background: rgba(255,255,255,0.03); padding: 4px 12px; border-radius: 40px; }
.live-indicator { display: flex; align-items: center; gap: 8px; background: rgba(0,0,0,0.4); padding: 6px 14px; border-radius: 40px; font-size: 0.7rem; }
.live-dot { width: 8px; height: 8px; background: var(--accent-secondary); border-radius: 50%; box-shadow: 0 0 8px var(--accent-secondary); animation: pulse-glow 1.8s infinite; }
@keyframes pulse-glow { 0%,100% { opacity: 0.7; } 50% { opacity: 1; transform: scale(1.2); } }
.icon-btn { background: rgba(255,255,255,0.04); border: 0.5px solid var(--glass-border); backdrop-filter: blur(12px); padding: 8px 16px; border-radius: 40px; font-size: 0.75rem; color: white; cursor: pointer; transition: 0.2s; }
.icon-btn:hover { background: rgba(0,229,255,0.12); transform: scale(0.98); }
.floating-dock {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8px;
  background: rgba(10, 12, 18, 0.75);
  backdrop-filter: blur(36px);
  border: 0.5px solid rgba(255,255,255,0.1);
  border-radius: 60px;
  padding: 8px 20px;
  z-index: 200;
  box-shadow: 0 12px 32px rgba(0,0,0,0.5);
}
.dock-item {
  background: transparent;
  border: none;
  padding: 8px 18px;
  border-radius: 40px;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text-secondary);
