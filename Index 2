<script>
// ======================== FULL ORIGINAL BUSINESS LOGIC (COMPLETE) ========================
const SHEET_ID = '1Y49X7Gj2Zy8XaX85ONHQTXnd3ItrmwPZHA2MXlRy4gU';
const SHEET_NAME = 'bacot';
const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(SHEET_NAME)}`;
let allData = [];
let charts = {};
let periodData = {};
let customPeriodData = {};
let fldtData = {};
let _weeklyChan = 'gmv', _customChan = 'gmv', _fldtChan = 'cup_total', _chTrendChan = 'offline', _periodMode = 'weekly', _fldtMode = 'weekly';
const HARI = ['Min','Sen','Sel','Rab','Kam','Jum','Sab'];
const TC = { gmv:'#f472b6', offline:'#60a5fa', online:'#34d399', gofood:'#fb923c', grabfood:'#4ade80', shopee:'#f87171', accent:'#00e5ff', accent2:'#00ff9d', amber:'#ffc233' };
const FLDT_KEYS = ['food_off','large_off','diary_off','topping_off','rtd_off','seasonal_sold'];
const FLDT_LABELS = ['Food','Large','Diary','Topping','RTD','Seasonal'];
const FLDT_COLORS = ['#00ff9d','#60a5fa','#a78bfa','#ffc233','#2dd4bf','#f472b6'];

const fmtRp = v => { v = v || 0; return v >= 1e6 ? 'Rp '+(v/1e6).toFixed(1)+'jt' : v >= 1e3 ? 'Rp '+(v/1e3).toFixed(0)+'rb' : 'Rp '+Math.round(v); };
const fmtNum = v => new Intl.NumberFormat('id-ID').format(Math.round(v||0));
const fmtPct = v => (v||0).toFixed(1)+'%';
const toInputDate = d => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
const parseNum = s => parseFloat(s?.replace(/[^0-9.-]/g,'')||0);
const pct = (a,b) => b ? a/b*100 : 0;
const safePct = (a,b) => b>0 ? ((a-b)/b*100) : 0;

function parseCSVLine(line) { const res=[]; let cur='', inQ=false; for(let i=0;i<line.length;i++){ if(line[i]==='"') inQ=!inQ; else if(line[i]===','&&!inQ){ res.push(cur); cur=''; } else cur+=line[i]; } res.push(cur); return res; }
function parseCSV(text){
  const lines=text.trim().split('\n');
  const headers=parseCSVLine(lines[0]).map(h=>h.trim().replace(/^"|"$/g,'').toUpperCase());
  const rows=[];
  for(let i=1;i<lines.length;i++){
    const vals=parseCSVLine(lines[i]);
    if(!vals[0]) continue;
    const row={};
    headers.forEach((h,idx)=>{ row[h]=(vals[idx]||'').trim().replace(/^"|"$/g,''); });
    let d=null;
    const raw=row['TANGGAL'];
    if(raw){
      const parts=raw.split('/');
      if(parts.length===3) d=new Date(parseInt(parts[2]),parseInt(parts[0])-1,parseInt(parts[1]));
      else d=new Date(raw);
    }
    if(!d||isNaN(d)) continue;
    row._date=d; row._dateStr=toInputDate(d);
    const numCols=['GMV','OFFLINE SALES','GOFOOD SALES','GRABFOOD SALES','SHOPE FOOD SALES','ADT STORE','ADT OFFLINE','ADT ONLINE','ADT GOFOOD','ADT GRABFOOD','ADT SHOPEFOOD','TOTAL SOLD CUP OFFLINE','FOOD OFFLINE','LARGE OFFLINE','DIARY OFFLINE','TOPPING OFFLINE','RTD OFFLINE','SEASONAL SOLD','IPT'];
    numCols.forEach(c=>{ row['_n_'+c]=parseNum(row[c]); });
    rows.push(row);
  }
  return rows.sort((a,b)=>a._date-b._date);
}
function filterData(s,e){ const start=new Date(s), end=new Date(e); end.setHours(23,59,59,999); return allData.filter(r=>r._date>=start&&r._date<=end).map(r=>({date:r._dateStr,gmv:r._n_GMV,offline:r._n_OFFLINE SALES,gofood:r._n_GOFOOD SALES,grabfood:r._n_GRABFOOD SALES,shopee:r._n_SHOPE FOOD SALES,adt_store:r._n_ADT STORE,adt_offline:r._n_ADT OFFLINE,adt_online:r._n_ADT ONLINE,adt_gofood:r._n_ADT GOFOOD,adt_grabfood:r._n_ADT GRABFOOD,adt_shopee:r._n_ADT SHOPEFOOD,cup_total:r._n_TOTAL SOLD CUP OFFLINE,food_off:r._n_FOOD OFFLINE,large_off:r._n_LARGE OFFLINE,diary_off:r._n_DIARY OFFLINE,topping_off:r._n_TOPPING OFFLINE,rtd_off:r._n_RTD OFFLINE,seasonal_sold:r._n_SEASONAL SOLD,ipt:r._n_IPT,offline_sales:r._n_OFFLINE SALES})); }
