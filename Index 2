.cmd-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; backdrop-filter: blur(48px); background: rgba(0,0,0,0.6); z-index: 1000; display: flex; align-items: center; justify-content: center; visibility: hidden; opacity: 0; transition: 0.2s; }
.cmd-modal.active { visibility: visible; opacity: 1; }
.cmd-panel { width: 560px; background: rgba(12, 16, 24, 0.88); backdrop-filter: blur(48px); border-radius: 48px; border: 0.5px solid rgba(255,255,255,0.1); padding: 20px; }
.cmd-input { width: 100%; background: rgba(0,0,0,0.5); border: none; padding: 16px 20px; border-radius: 60px; font-size: 1rem; color: white; outline: none; }
