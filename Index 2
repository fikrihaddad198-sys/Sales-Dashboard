.toast { position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.7); backdrop-filter: blur(40px); border-radius: 60px; padding: 10px 22px; color: white; font-size: 0.8rem; z-index: 300; opacity: 0; transition: 0.2s; pointer-events: none; }
