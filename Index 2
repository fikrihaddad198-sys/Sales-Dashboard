<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}
:root {
  --bg-deep: #050505;
  --glass-bg: rgba(18, 22, 28, 0.45);
  --glass-border: rgba(255, 255, 255, 0.06);
  --glass-border-light: rgba(255, 255, 255, 0.12);
  --accent-primary: #00e5ff;
  --accent-secondary: #00ff9d;
  --text-primary: #ffffff;
  --text-secondary: #b0b8c5;
  --text-tertiary: #6b7280;
  --card-radius: 32px;
  --dock-radius: 60px;
  --transition-smooth: cubic-bezier(0.2, 0.9, 0.4, 1.1);
  --transition-spring: cubic-bezier(0.34, 1.3, 0.55, 1);
  --shadow-glass: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 0 0.5px rgba(255, 255, 255, 0.02) inset;
}
body {
  background: var(--bg-deep);
  font-family: 'Inter', -apple-system, 'SF Pro Text', sans-serif;
  color: var(--text-primary);
  overflow-x: hidden;
  min-height: 100vh;
}
.aurora-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  background: radial-gradient(circle at 20% 30%, rgba(0, 40, 50, 0.6), transparent 60%),
              radial-gradient(circle at 80% 70%, rgba(0, 255, 157, 0.12), transparent 70%);
  animation: auroraShift 24s infinite alternate;
}
@keyframes auroraShift {
  0% { opacity: 0.5; transform: scale(1); }
  100% { opacity: 1; transform: scale(1.02); }
}
.noise-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='1' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.028'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: -1;
  opacity: 0.4;
}
.glass-header {
  position: sticky;
  top: 0;
  backdrop-filter: blur(32px);
  background: rgba(5, 5, 5, 0.55);
  border-bottom: 0.5px solid var(--glass-border);
  padding: 12px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
