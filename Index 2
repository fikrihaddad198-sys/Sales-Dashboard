function calcKpi(){
  const s=document.getElementById('kpi-start').value, e=document.getElementById('kpi-end').value;
  if(!s||!e||!allData.length) return;
  const rows=filterData(s,e); if(!rows.length) return;
  const target=parseNum(document.getElementById('kpi-target').value);
  const totalDays=parseInt(document.getElementById('kpi-days').value)||30;
  const data=aggregateData(rows); const elapsed=rows.length;
  const dailyTarget=target/totalDays; const avgDaily=data.gmv/elapsed;
  const remaining=Math.max(0,totalDays-elapsed); const forecastEom=data.gmv+avgDaily*remaining;
  const achPct=target?pct(data.gmv,target):0; const idealPct=pct(elapsed,totalDays); const vsIdeal=achPct-idealPct;
  const total=data.offline+data.gofood+data.grabfood+data.shopee||1;
  const contrib={offline:pct(data.offline,total),gofood:pct(data.gofood,total),grabfood:pct(data.grabfood,total),shopee:pct(data.shopee,total)};
  const kpis=[{l:'Target GMV',v:fmtRp(target)},{l:'Current GMV',v:fmtRp(data.gmv)},{l:'Achievement',v:fmtPct(achPct)},{l:'Daily Target',v:fmtRp(dailyTarget)},{l:'Avg Daily GMV',v:fmtRp(avgDaily)},{l:'Forecast EOM',v:fmtRp(forecastEom)}];
  document.getElementById('kpi-cards').innerHTML=kpis.map(k=>`<div class="kpi-card"><div class="kpi-lbl">${k.l}</div><div class="kpi-val">${k.v}</div></div>`).join('');
  destroyChart('gauge'); const gaugePct=Math.min(achPct,100);
  charts.gauge=new Chart(document.getElementById('gaugeChart'),{type:'doughnut',data:{datasets:[{data:[gaugePct,100-gaugePct],backgroundColor:[TC.accent2,'rgba(255,255,255,0.05)'],borderWidth:0,circumference:220,rotation:-110}]},options:{cutout:'80%',plugins:{legend:{display:false}}}});
  document.getElementById('gauge-pct').innerHTML=fmtPct(achPct);
  const contribHtml=Object.entries(contrib).map(([k,v])=>`<div><div>${k}</div><div class="chan-track"><div style="width:${v}%;background:${TC[k]||TC.accent}"></div></div><div>${fmtPct(v)}</div></div>`).join('');
  document.getElementById('kpi-contrib').innerHTML=contribHtml;
  const ma7=computeMA(rows,'gmv',7); destroyChart('kpiTrend');
  charts.kpiTrend=new Chart(document.getElementById('kpi-trend-chart'),{type:'line',data:{labels:rows.map(r=>r.date.slice(5)),datasets:[{label:'GMV',data:rows.map(r=>r.gmv),borderColor:TC.gmv},{label:'7D MA',data:ma7.map(m=>m.value),borderColor:TC.amber,borderDash:[5,5]}]},options:baseOptions()});
  destroyChart('kpiStacked');
  charts.kpiStacked=new Chart(document.getElementById('kpi-stacked-chart'),{type:'bar',data:{labels:rows.map(r=>r.date.slice(5)),datasets:[{label:'Offline',data:rows.map(r=>r.offline),backgroundColor:TC.offline},{label:'GoFood',data:rows.map(r=>r.gofood),backgroundColor:TC.gofood},{label:'GrabFood',data:rows.map(r=>r.grabfood),backgroundColor:TC.grabfood},{label:'Shopee',data:rows.map(r=>r.shopee),backgroundColor:TC.shopee}]},options:{...baseOptions(),scales:{x:{stacked:true},y:{stacked:true}}}});
}

