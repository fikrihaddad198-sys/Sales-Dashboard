.glass-card:hover { border-color: rgba(0,229,255,0.2); transform: translateY(-2px); }
.page { opacity: 0; transform: scale(0.98); transition: opacity 0.35s var(--transition-smooth), transform 0.4s var(--transition-spring); display: none; }
.page.active { display: block; opacity: 1; transform: scale(1); }
.app-body { padding: 24px 28px 100px 28px; max-width: 1600px; margin: 0 auto; }
.kpi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); gap: 16px; margin-bottom: 24px; }
