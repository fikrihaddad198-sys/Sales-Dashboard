.inp { background: rgba(0,0,0,0.6); border: 1px solid var(--glass-border); border-radius: 60px; padding: 8px 16px; color: white; font-size: 0.75rem; }
.btn { background: var(--accent-primary); border: none; border-radius: 60px; padding: 8px 20px; font-weight: 600; cursor: pointer; transition: 0.2s; }
